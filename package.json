{
  "name": "@theyahia/planfix-mcp",
  "version": "1.0.0",
  "description": "MCP server for Planfix API — tasks, projects, contacts, comments. 10 tools, 2 skills.",
  "type": "module",
  "main": "dist/index.js",
  "bin": { "planfix-mcp": "dist/index.js" },
  "files": ["dist"],
  "engines": { "node": ">=18.0.0" },
  "scripts": {
    "build": "tsc",
    "dev": "tsx src/index.ts",
    "start": "node dist/index.js",
    "start:http": "node dist/index.js --http 8080",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepublishOnly": "npm run build && npm run test"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "vitest": "^3.1.1"
  },
  "publishConfig": { "access": "public" },
  "mcpName": "io.github.theYahia/planfix-mcp",
  "keywords": ["mcp", "mcp-server", "model-context-protocol", "claude", "ai", "russian-api", "planfix", "project-management", "crm", "streamable-http", "smithery"],
  "license": "MIT",
  "repository": { "type": "git", "url": "https://github.com/theYahia/planfix-mcp.git" },
  "homepage": "https://github.com/theYahia/planfix-mcp#readme",
  "author": "theYahia (https://github.com/theYahia)"
}
